# ============================================================
# Production .env — Domainesia (stmik.sosmartpro.com)
# Salin ke `.env` di server lalu sesuaikan password sebelum start.
# JANGAN commit file ini ke git.
# ============================================================

NODE_ENV=production

# Port — Passenger akan inject PORT-nya sendiri, ini fallback.
API_PORT=4000

# Database MySQL (Domainesia shared) — biasanya localhost
# Format: mysql://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL="mysql://sosmartp_admin:19Feb2018.@localhost:3306/sosmartp_stmik"

# JWT secrets — JANGAN dipakai default; ganti pakai output:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=c0c54a42df9557392508bed8795b89683c641dc6a10ea9c441407da0aad393b074ea88d9ef696a79d8c6669a57018fadc165b0a183dfd21ac971d7eeecbbba9c
JWT_REFRESH_SECRET=835228274a6c1d47417da012073f0587b1133dcaa09f47282fef88f06c4afa33d0711dd8497037def980cd1196c99e09bd50b6260b65c0fce21618dbb7235cfe
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — same-origin, set domain produksi
CORS_ORIGINS=https://stmik.sosmartpro.com

# Frontend URL utk link di email notifikasi
FRONTEND_URL=https://stmik.sosmartpro.com

# SMTP — opsional. Kalau kosong, email akan di-log ke console saja.
# Contoh setup pakai Mailtrap/Brevo/SendGrid:
# SMTP_HOST=smtp.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
MAIL_FROM=SIAKAD STMIK Tazkia <no-reply@stmik.sosmartpro.com>
