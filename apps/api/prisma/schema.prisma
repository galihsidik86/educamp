// ============================================================
// Tazkia SIAKAD — database schema
// MySQL 8.x  |  Prisma 5.x
// Domain: PDDikti-friendly academic information system covering
// auth, master data, kurikulum, KRS, nilai, keuangan, penelitian,
// pengabdian masyarakat, KKN.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

enum Role {
  mahasiswa
  dosen
  akademik
  wali
}

/// Sub-peran untuk user dengan role 'akademik' — membagi akses BAAK.
/// super_admin: akses semua, override sub-role lain.
/// akademik: akses fitur akademik core (mahasiswa, dosen, kurikulum, KRS, dst.).
/// keuangan: akses fitur keuangan (tagihan, pembayaran, UKT, heregistrasi).
/// prodi: akses fitur per-prodi (akreditasi, OBE, laporan prodi).
/// spmi: akses fitur penjaminan mutu (SPMI standar, AMI, RTM, survei).
enum AkademikSubRole {
  super_admin
  akademik
  keuangan
  prodi
  spmi
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  passwordMustChange Boolean @default(false) // user wajib ganti password sesi berikutnya
  lastLoginAt  DateTime?

  mahasiswa    Mahasiswa?
  dosen        Dosen?
  akademik     Akademik?
  wali         Wali?
  refreshTokens RefreshToken[]
  notifikasi   Notifikasi[]
  tiketReply   TiketReply[]
  dokumenAkses DokumenAkses[]
  capaPic      TindakLanjutCapa[] @relation("CapaPic")
  keputusanRtmPic KeputusanRtm[]  @relation("KeputusanRtmPic")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ============================================================
// ORGANISASI & PROGRAM STUDI
// ============================================================

model Fakultas {
  id        String  @id @default(uuid())
  kode      String  @unique
  nama      String
  prodi     Prodi[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Identitas institusi (singleton, id="singleton") — dipakai sebagai sumber
/// nama kampus untuk kop laporan, header verifikasi publik, sidebar brand, dll.
model InstitusiConfig {
  id                 String   @id @default("singleton")
  // Identitas utama
  nama               String              // "Institut Agama Islam Tazkia"
  namaPendek         String?             // "IAI Tazkia" — utk sidebar/kompak
  tagline            String?             // "Portal Akademik" / "SIAKAD"
  akreditasiPT       String?             // "Unggul" / "A" / "B"
  akreditasiSk       String?             // No SK akreditasi institusi
  // Alamat & kontak
  alamat             String?             @db.Text
  kota               String?             // "Bogor"
  kodePos            String?
  telepon            String?
  email              String?
  website            String?
  // Branding
  logoUrl            String?             @db.Text
  logoInverseUrl     String?             @db.Text  // untuk dark/navy chrome
  // Pejabat penandatangan default (untuk kop laporan & cetakan)
  rektorNama         String?
  rektorNip          String?
  rektorJabatan      String?             @default("Rektor")
  bagianAkademikNama String?             @default("Bagian Akademik (BAAK)")
  kepalaBaakNama     String?
  // Kop surat (multiline) — untuk dokumen formal
  kopSurat           String?             @db.Text

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum Jenjang {
  d3
  d4
  s1
  s2
  s3
  profesi
  ppg     // Pendidikan Profesi Guru
  sp1     // Spesialis 1
  sp2     // Spesialis 2
}

// Jenis pendaftaran mahasiswa — wajib untuk PDDikti Neo Feeder.
// "baru" = penerimaan reguler, "pindahan" = transfer dari PT lain,
// "lanjutan" = lanjut jenjang (D3→S1), "ppg" = pendaftaran PPG,
// "transfer" = transfer internal lintas prodi, "rpl" = rekognisi
// pembelajaran lampau.
enum JenisPendaftaran {
  baru
  pindahan
  lanjutan
  ppg
  transfer
  rpl
}

model Prodi {
  id         String   @id @default(uuid())
  kode       String   @unique // kode prodi PDDikti
  nama       String
  jenjang    Jenjang
  fakultasId String
  fakultas   Fakultas @relation(fields: [fakultasId], references: [id])
  // Default tarif UKT per semester — fallback kalau mahasiswa belum di-assign kategori UKT
  // (akan dihapus di masa depan setelah migrasi data; sementara dibiarkan utk backward compat).
  tarifSppDefault Decimal? @db.Decimal(15, 2)
  // Uang pangkal — sekali bayar saat mahasiswa diterima (registrasi/initial fee)
  tarifUangPangkal Decimal? @db.Decimal(15, 2)

  kategoriUkt KategoriUkt[]

  mahasiswa  Mahasiswa[]
  dosen      Dosen[]
  mataKuliah MataKuliah[]
  kurikulum  Kurikulum[]
  cpl        Cpl[]
  mutasiAsal   MutasiMahasiswa[] @relation("MutasiProdiAsal")
  mutasiTujuan MutasiMahasiswa[] @relation("MutasiProdiTujuan")
  lingkupAmi   LingkupAmi[]
  akademikAdmins Akademik[]
  standarMutu  StandarMutu[]
  dayaTampung  DayaTampungProdi[]
  inboundTujuan MahasiswaInbound[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fakultasId])
}

/// Kategori/kelompok UKT per Prodi. Mahasiswa di-assign ke salah satu kategori
/// (biasanya berdasarkan kondisi ekonomi keluarga / jalur masuk).
/// Beasiswa kalau diterima akan mengurangi tagihan UKT (penuh atau parsial).
model KategoriUkt {
  id              String   @id @default(uuid())
  prodiId         String
  prodi           Prodi    @relation(fields: [prodiId], references: [id])
  kode            String   // "UKT-1", "UKT-2", "MANDIRI"
  nama            String   // "Kelompok I", "Kelompok II", "Jalur Mandiri"
  nominalSemester Decimal  @db.Decimal(15, 2) // UKT per semester
  deskripsi       String?  @db.Text
  isAktif         Boolean  @default(true)

  mahasiswa       Mahasiswa[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([prodiId, kode])
  @@index([prodiId])
}

// ============================================================
// PERAN — Mahasiswa, Dosen, Akademik
// ============================================================

enum JenisKelamin {
  L
  P
}

enum StatusMahasiswa {
  aktif
  cuti
  lulus
  drop_out
  mengundurkan_diri
}

model Mahasiswa {
  id           String           @id @default(uuid())
  userId       String           @unique
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  nim          String           @unique
  nama         String
  jenisKelamin JenisKelamin
  tempatLahir  String?
  tanggalLahir DateTime?
  alamat       String?          @db.Text
  telepon      String?
  angkatan     Int
  prodiId      String
  prodi        Prodi            @relation(fields: [prodiId], references: [id])
  status       StatusMahasiswa  @default(aktif)
  dpaId        String?
  dpa          Dosen?           @relation("DpaMahasiswa", fields: [dpaId], references: [id])
  // Kategori UKT — menentukan nominal tagihan UKT per semester. Null = pakai Prodi.tarifSppDefault (fallback).
  kategoriUktId String?
  kategoriUkt   KategoriUkt?    @relation(fields: [kategoriUktId], references: [id])
  // Preferensi cicilan UKT default tiap kali validasi KRS. 1 = sekaligus, 2-12 = N cicilan bulanan.
  defaultCicilanUkt Int          @default(1)

  krs                 Krs[]
  nilai               Nilai[]
  absensi             Absensi[]
  tagihan             Tagihan[]
  pembayaran          Pembayaran[]
  penelitianMahasiswa PenelitianMahasiswa[]
  pengabdianMahasiswa PengabdianMahasiswa[]
  kkn                 Kkn[]
  mbkm                Mbkm[]
  edomResponse        EdomResponse[]
  skripsi             Skripsi[]
  yudisium            Yudisium[]
  beasiswa            PendaftaranBeasiswa[]
  submitTugas         SubmitTugas[]
  surat               Surat[]
  forumThread         ForumThread[]
  forumReply          ForumReply[]
  konsultasi          KonsultasiDpa[]
  kuisAttempt         KuisAttempt[]
  tiket               Tiket[]
  sertifikasi         Sertifikasi[]
  prestasi            Prestasi[]
  mutasi              MutasiMahasiswa[]
  wali                WaliMahasiswa[]
  sertifikatDigital   SertifikatDigital[]
  heregistrasi        Heregistrasi[]
  orangTua            OrangTuaMahasiswa[]

  // ============================================================
  // PDDikti biodata extension — Phase 1 Neo Feeder readiness.
  // Semua nullable supaya migrasi aman, di-lengkapi via import/update.
  // ============================================================
  nik                  String?  @db.VarChar(16)   // 16 digit KTP, unique kalau diisi
  nisn                 String?  @db.VarChar(10)   // 10 digit Nomor Induk Siswa Nasional
  npsn                 String?  @db.VarChar(10)   // NPSN sekolah asal
  namaSekolahAsal      String?
  jenisSekolahAsal     String?                    // negeri/swasta/luar_negeri/paket_c
  tahunLulusSekolah    Int?
  kewarganegaraan      String?  @default("Indonesia")
  kodeWilayahAlamat    String?  @db.VarChar(8)    // BPS 6-8 digit
  pembiayaan           String?                    // mandiri/beasiswa/kip_kuliah/sponsorship
  kebutuhanKhusus      String?                    // kode disabilitas PDDikti
  semesterAwal         String?  @db.VarChar(5)    // YYYYS (mis. "20211")

  // Reference relations
  agamaKode            Int?
  agama                KodeAgama?            @relation(fields: [agamaKode], references: [kode])
  jenisTinggalKode     Int?
  jenisTinggal         KodeJenisTinggal?     @relation(fields: [jenisTinggalKode], references: [kode])
  alatTransportasiKode Int?
  alatTransportasi     KodeAlatTransportasi? @relation(fields: [alatTransportasiKode], references: [kode])
  jalurMasukKode       String?
  jalurMasuk           KodeJalurMasuk?       @relation(fields: [jalurMasukKode], references: [kode])

  // Jenis pendaftaran (Phase 2 PDDikti) — baru/pindahan/lanjutan/ppg/transfer/rpl.
  jenisPendaftaran     JenisPendaftaran?     @default(baru)
  tanggalMasuk         DateTime?             // tanggal masuk PT (untuk history pendidikan)

  // Phase 2 — relasi tambahan
  akm                  AktivitasKuliahMahasiswa[]
  pesertaAktivitas     PesertaAktivitas[]
  nilaiTransfer        NilaiTransfer[]

  // PDDikti / Neo Feeder sync metadata
  feederId      String?  @unique // UUID dari Feeder, idempotensi
  lastSyncedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([prodiId])
  @@index([angkatan])
  @@index([status])
  @@index([nik])
}

enum JabatanFungsional {
  asisten_ahli
  lektor
  lektor_kepala
  guru_besar
  tenaga_pengajar
}

model Dosen {
  id                 String              @id @default(uuid())
  userId             String              @unique
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  nidn               String              @unique
  nama               String
  gelarDepan         String?
  gelarBelakang      String?
  prodiId            String
  prodi              Prodi               @relation(fields: [prodiId], references: [id])
  jabatanFungsional  JabatanFungsional?
  jabatanStruktural  String?
  isDpa              Boolean             @default(false)

  mahasiswaBimbingan Mahasiswa[]         @relation("DpaMahasiswa")
  kelas              Kelas[]
  penelitian         Penelitian[]
  pengabdian         Pengabdian[]
  kknBimbingan       Kkn[]               @relation("DplKkn")
  mbkmBimbingan      Mbkm[]              @relation("DplMbkm")
  pembimbing1Skripsi Skripsi[]           @relation("Pembimbing1Skripsi")
  pembimbing2Skripsi Skripsi[]           @relation("Pembimbing2Skripsi")
  forumThread        ForumThread[]
  forumReply         ForumReply[]
  kelasTeam          KelasDosen[]
  konsultasi         KonsultasiDpa[]
  bkdLaporan         BkdLaporan[]
  auditorAmi         AuditorAmi[]
  capaPic            TindakLanjutCapa[] @relation("CapaPicDosen")
  pembimbingAktivitas PembimbingAktivitas[]

  // ============================================================
  // PDDikti biodata extension — Phase 1 Neo Feeder readiness.
  // ============================================================
  nik                          String?  @db.VarChar(16)
  nip                          String?  @db.VarChar(20)
  nuk                          String?  @db.VarChar(20)
  statusKepegawaian            String?  // pns/tetap_non_pns/kontrak/dosen_lb
  statusKeaktifan              String?  @default("aktif") // aktif/tugas_belajar/tugas_luar/pensiun/cuti
  pendidikanTerakhirJenjang    String?  // s1/s2/s3/d3/d4/profesi
  pendidikanTerakhirGelar      String?
  pendidikanTerakhirTahunLulus Int?
  pendidikanTerakhirBidang     String?
  pangkatGolongan              String?  // mis "III/b" untuk PNS
  tanggalMulaiKerja            DateTime?
  serdosStatus                 Boolean? @default(false) // sertifikasi dosen
  serdosTanggal                DateTime?
  agamaKode                    Int?
  agamaDosen                   KodeAgama? @relation("DosenAgama", fields: [agamaKode], references: [kode])

  // PDDikti / Neo Feeder sync metadata
  feederId           String?             @unique
  lastSyncedAt       DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([prodiId])
}

model Akademik {
  id        String          @id @default(uuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  nip       String?         @unique
  nama      String
  jabatan   String?

  /// Sub-peran — menentukan menu & endpoint yang bisa diakses.
  /// Default super_admin supaya akun lama tetap punya akses penuh.
  subRole   AkademikSubRole @default(super_admin)

  /// Untuk admin prodi — scope opsional ke 1 prodi tertentu.
  /// Implementasi scope filtering Phase 2; saat ini hanya menentukan menu.
  prodiId   String?
  prodi     Prodi?          @relation(fields: [prodiId], references: [id])

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ============================================================
// PERIODE AKADEMIK
// ============================================================

model TahunAjaran {
  id           String     @id @default(uuid())
  kode         String     @unique // "2025/2026"
  nama         String
  tahunMulai   Int
  tahunSelesai Int
  isAktif      Boolean    @default(false)

  semester     Semester[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum JenisSemester {
  ganjil
  genap
  pendek
}

model Semester {
  id            String        @id @default(uuid())
  tahunAjaranId String
  tahunAjaran   TahunAjaran   @relation(fields: [tahunAjaranId], references: [id])
  jenis         JenisSemester
  kode          String        @unique // "20251" "20252"

  krsMulai      DateTime?
  krsSelesai    DateTime?
  prsMulai      DateTime?
  prsSelesai    DateTime?
  nilaiMulai    DateTime?
  nilaiSelesai  DateTime?

  isAktif       Boolean       @default(false)

  kelas         Kelas[]
  krs           Krs[]
  tagihan       Tagihan[]
  edomKuesioner EdomKuesioner[]
  kalender      KalenderAkademik[]
  mutasi        MutasiMahasiswa[]
  bkdLaporan    BkdLaporan[]
  heregistrasi  Heregistrasi[]
  akm           AktivitasKuliahMahasiswa[]
  aktivitas     AktivitasMahasiswa[]
  dayaTampung   DayaTampungProdi[]
  inbound       MahasiswaInbound[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tahunAjaranId])
  @@index([isAktif])
}

// ============================================================
// KURIKULUM & MATA KULIAH
// ============================================================

model Kurikulum {
  id        String                @id @default(uuid())
  kode      String                @unique // "K2024"
  nama      String
  tahun     Int
  prodiId   String
  prodi     Prodi                 @relation(fields: [prodiId], references: [id])
  isAktif   Boolean               @default(false)

  mataKuliah MataKuliahKurikulum[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([prodiId])
}

enum JenisMK {
  wajib_universitas
  wajib_prodi
  pilihan
}

// Kelompok Mata Kuliah — klasifikasi kurikulum (independen dari jenis wajib/pilihan).
// MKWU = Wajib Umum (Agama, Pancasila, Kewarganegaraan, B.Indo — Kemendikbud)
// MKDK = Dasar Kependidikan/Keahlian
// MKWK = Wajib Kurikulum/Kompetensi
// MKK  = Keilmuan dan Keterampilan
// MKB  = Keahlian Berkarya
// MPK  = Pengembangan Kepribadian
enum KelompokMatkul {
  MKWU
  MKDK
  MKWK
  MKK
  MKB
  MPK
}

model MataKuliah {
  id          String                @id @default(uuid())
  // Kode unik PER PRODI (bukan global) — MKWU/MKDU spt "Bahasa Inggris" boleh
  // memakai kode yang sama di banyak prodi, sesuai model PDDikti (MK dimiliki
  // & didaftarkan per prodi). Lihat @@unique([prodiId, kode]) di bawah.
  kode        String                // "IF-3101"
  nama        String
  namaInggris String?
  sks         Int
  sksTeori    Int                   @default(0)
  sksPraktik  Int                   @default(0)
  sksLapangan Int                   @default(0)
  sksSimulasi Int                   @default(0)
  jenis       JenisMK               @default(wajib_prodi)
  prodiId     String
  prodi       Prodi                 @relation(fields: [prodiId], references: [id])

  // PDDikti Phase 2 — IKU 7 + Kelompok MK
  linkRps        String?            @db.Text  // URL RPS untuk reporting IKU 7
  bidangIlmu     String?                      // Bidang ilmu PDDikti
  kelompokMatkul KelompokMatkul?              // MKWU/MKDK/MKWK/MKK/MKB/MPK
  deskripsi      String?            @db.Text  // ringkasan substansi

  kurikulum     MataKuliahKurikulum[]
  kelas         Kelas[]
  prasyarat     Prasyarat[]         @relation("MKUtama")
  prasyaratDari Prasyarat[]         @relation("MKPrasyarat")
  mbkmKonversi  MbkmKonversi[]
  cpmk          Cpmk[]
  nilaiTransfer NilaiTransfer[]

  feederId    String?               @unique
  lastSyncedAt DateTime?

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([prodiId, kode])
  @@index([prodiId])
}

model MataKuliahKurikulum {
  id           String     @id @default(uuid())
  kurikulumId  String
  kurikulum    Kurikulum  @relation(fields: [kurikulumId], references: [id])
  mataKuliahId String
  mataKuliah   MataKuliah @relation(fields: [mataKuliahId], references: [id])
  semester     Int

  @@unique([kurikulumId, mataKuliahId])
  @@index([kurikulumId])
}

model Prasyarat {
  id            String     @id @default(uuid())
  mkUtamaId     String
  mkUtama       MataKuliah @relation("MKUtama", fields: [mkUtamaId], references: [id])
  mkPrasyaratId String
  mkPrasyarat   MataKuliah @relation("MKPrasyarat", fields: [mkPrasyaratId], references: [id])
  nilaiMinimal  String?

  @@unique([mkUtamaId, mkPrasyaratId])
}

// ============================================================
// PERKULIAHAN — Kelas, Jadwal, KRS, Nilai
// ============================================================

model Ruangan {
  id        String   @id @default(uuid())
  kode      String   @unique
  nama      String
  gedung    String?
  lantai    Int?
  kapasitas Int      @default(0)

  kelas     Kelas[]
  pertemuan Pertemuan[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Hari {
  senin
  selasa
  rabu
  kamis
  jumat
  sabtu
  minggu
}

// Metode pembelajaran per kelas — IKU 7 reporting.
enum MetodePembelajaran {
  tatap_muka
  daring
  blended       // hybrid
}

model Kelas {
  id           String     @id @default(uuid())
  mataKuliahId String
  mataKuliah   MataKuliah @relation(fields: [mataKuliahId], references: [id])
  semesterId   String
  semester     Semester   @relation(fields: [semesterId], references: [id])
  dosenId      String
  dosen        Dosen      @relation(fields: [dosenId], references: [id])
  ruanganId    String?
  ruangan      Ruangan?   @relation(fields: [ruanganId], references: [id])
  kodeKelas    String     // "A", "B"
  kapasitas    Int        @default(40)
  hari         Hari?
  jamMulai     String?    // "08:00"
  jamSelesai   String?    // "09:40"

  // PDDikti Phase 2 — IKU 7
  metodePembelajaran MetodePembelajaran? @default(tatap_muka)

  krs          Krs[]
  pertemuan    Pertemuan[]
  edomResponse EdomResponse[]
  bahanAjar    BahanAjar[]
  tugas        Tugas[]
  kuis         Kuis[]
  forumThread  ForumThread[]
  team         KelasDosen[]
  bobotNilai   BobotNilaiKelas?
  komponenEvaluasi KomponenEvaluasiKelas[]

  feederId     String?    @unique
  lastSyncedAt DateTime?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([mataKuliahId, semesterId, kodeKelas])
  @@index([semesterId])
  @@index([dosenId])
}

// ============================================================
// BOBOT NILAI per kelas — dosen pengampu menentukan persentase
// komponen (tugas/UTS/UAS/praktikum/kehadiran). Jumlah harus 100%.
// Tanpa konfigurasi: dosen tetap bisa input nilaiAngka manual.
// ============================================================
model BobotNilaiKelas {
  id              String   @id @default(uuid())
  kelasId         String   @unique
  kelas           Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  bobotTugas      Float    @default(20)
  bobotUts        Float    @default(30)
  bobotUas        Float    @default(40)
  bobotPraktikum  Float    @default(0)
  bobotKehadiran  Float    @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// TEAM TEACHING — banyak dosen per kelas dengan peran
// ============================================================

enum PeranKelasDosen {
  lead       // pengampu utama
  anggota    // dosen team dengan akses penuh
  asisten    // asisten dengan akses terbatas
}

model KelasDosen {
  id        String          @id @default(uuid())
  kelasId   String
  kelas     Kelas           @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  dosenId   String
  dosen     Dosen           @relation(fields: [dosenId], references: [id])
  peran     PeranKelasDosen @default(anggota)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([kelasId, dosenId])
  @@index([dosenId])
}

model Pertemuan {
  id          String    @id @default(uuid())
  kelasId     String
  kelas       Kelas     @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  pertemuanKe Int       // 1, 2, 3, …
  tanggal     DateTime
  topik       String?   @db.Text
  catatan     String?   @db.Text

  // Reschedule metadata — diisi saat pertemuan dipindah dari jadwal awal.
  tanggalAsli       DateTime? // snapshot tanggal sebelum pertama kali dipindah
  alasanReschedule  String?   @db.Text
  direschedulePada  DateTime?
  ruanganId         String?   // override ruangan utk sesi ini saja (opsional)
  ruangan           Ruangan?  @relation(fields: [ruanganId], references: [id])

  // Self-check-in via PIN/QR
  pinKehadiran  String?   // 6 digit; null = tidak aktif / sudah di-clear
  pinExpiresAt  DateTime?
  pinDibuatPada DateTime?

  absensi     Absensi[]
  bahanAjar   BahanAjar[]
  tugas       Tugas[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([kelasId, pertemuanKe])
  @@index([kelasId])
  @@index([tanggal])
  @@index([ruanganId])
}

enum JenisBahanAjar {
  link
  file
  text
  video
}

model BahanAjar {
  id          String          @id @default(uuid())
  kelasId     String
  kelas       Kelas           @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  pertemuanId String?
  pertemuan   Pertemuan?      @relation(fields: [pertemuanId], references: [id], onDelete: SetNull)

  jenis       JenisBahanAjar
  judul       String
  deskripsi   String?         @db.Text
  url         String?         @db.Text
  konten      String?         @db.Text
  urutan      Int             @default(0)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kelasId])
  @@index([pertemuanId])
}

// ============================================================
// TUGAS — assignment + submission mahasiswa
// ============================================================

enum StatusSubmitTugas {
  terkumpul
  terlambat
  dinilai
}

enum JenisTugas {
  tugas
  uts
  uas
  praktikum
}

model Tugas {
  id            String         @id @default(uuid())
  kelasId       String
  kelas         Kelas          @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  pertemuanId   String?
  pertemuan     Pertemuan?     @relation(fields: [pertemuanId], references: [id], onDelete: SetNull)

  judul         String
  deskripsi     String?        @db.Text
  deadline      DateTime
  maxNilai      Int            @default(100)
  linkLampiran  String?        @db.Text
  /// Komponen penilaian tujuan sinkronisasi nilai submission.
  /// Default 'tugas' agar data lama tidak berubah perilaku.
  jenis         JenisTugas     @default(tugas)

  submission    SubmitTugas[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([kelasId])
  @@index([deadline])
}

model SubmitTugas {
  id            String            @id @default(uuid())
  tugasId       String
  tugas         Tugas             @relation(fields: [tugasId], references: [id], onDelete: Cascade)
  mahasiswaId   String
  mahasiswa     Mahasiswa         @relation(fields: [mahasiswaId], references: [id])

  linkJawaban   String?           @db.Text
  isiJawaban    String?           @db.Text
  waktuSubmit   DateTime          @default(now())
  terlambat     Boolean           @default(false)

  nilai         Float?
  catatan       String?           @db.Text
  status        StatusSubmitTugas @default(terkumpul)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([tugasId, mahasiswaId])
  @@index([tugasId])
  @@index([mahasiswaId])
}

// ============================================================
// FORUM DISKUSI per Kelas
// ============================================================

model ForumThread {
  id              String        @id @default(uuid())
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  authorMahasiswaId String?
  authorMahasiswa   Mahasiswa?  @relation(fields: [authorMahasiswaId], references: [id])
  authorDosenId     String?
  authorDosen       Dosen?      @relation(fields: [authorDosenId], references: [id])

  judul         String
  isi           String        @db.Text
  isPinned      Boolean       @default(false)
  isLocked      Boolean       @default(false)

  replies       ForumReply[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([kelasId])
  @@index([isPinned])
}

model ForumReply {
  id            String        @id @default(uuid())
  threadId      String
  thread        ForumThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorMahasiswaId String?
  authorMahasiswa   Mahasiswa? @relation(fields: [authorMahasiswaId], references: [id])
  authorDosenId     String?
  authorDosen       Dosen?     @relation(fields: [authorDosenId], references: [id])

  isi           String        @db.Text

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([threadId])
}

enum StatusAbsensi {
  hadir
  izin
  sakit
  alpa
}

model Absensi {
  id          String        @id @default(uuid())
  pertemuanId String
  pertemuan   Pertemuan     @relation(fields: [pertemuanId], references: [id], onDelete: Cascade)
  mahasiswaId String
  mahasiswa   Mahasiswa     @relation(fields: [mahasiswaId], references: [id])
  status      StatusAbsensi @default(alpa)
  catatan     String?       @db.Text

  // Audit input — terutama saat self-check-in via PIN/QR
  inputViaPin    Boolean   @default(false)
  inputPada      DateTime?
  inputIp        String?
  inputUserAgent String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([pertemuanId, mahasiswaId])
  @@index([mahasiswaId])
}

enum StatusKrs {
  draft
  diajukan
  disetujui
  ditolak
}

model Krs {
  id          String    @id @default(uuid())
  mahasiswaId String
  mahasiswa   Mahasiswa @relation(fields: [mahasiswaId], references: [id])
  kelasId     String
  kelas       Kelas     @relation(fields: [kelasId], references: [id])
  semesterId  String
  semester    Semester  @relation(fields: [semesterId], references: [id])
  status      StatusKrs @default(draft)
  catatan     String?   @db.Text

  nilai       Nilai?
  nilaiCpmk   NilaiCpmk[]
  nilaiKomponen NilaiKomponenEvaluasi[]

  feederId    String?   @unique
  lastSyncedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([mahasiswaId, kelasId])
  @@index([semesterId])
  @@index([status])
}

enum StatusNilai {
  belum
  draft
  finalized
}

model Nilai {
  id          String       @id @default(uuid())
  krsId       String       @unique
  krs         Krs          @relation(fields: [krsId], references: [id], onDelete: Cascade)
  mahasiswaId String
  mahasiswa   Mahasiswa    @relation(fields: [mahasiswaId], references: [id])

  tugas       Float?
  uts         Float?
  uas         Float?
  praktikum   Float?
  kehadiran   Float?

  nilaiAngka  Float?
  nilaiHuruf  String?      // A AB B BC C D E
  bobot       Float?       // 4 3.5 3 2.5 2 1 0
  status      StatusNilai  @default(belum)

  feederId    String?      @unique
  lastSyncedAt DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([mahasiswaId])
}

// ============================================================
// KONFIGURASI SKALA NILAI
// Single-row config — admin akademik atur threshold huruf + bobot.
// Default = standar Kemendikbud (A≥85, AB≥75, B≥70, BC≥65, C≥56, D≥40).
// ============================================================
model KonfigurasiSkalaNilai {
  id        String   @id @default(uuid())
  // Threshold nilai minimum per slot (E selalu implicit 0)
  minA      Float    @default(85)
  minAB     Float    @default(75)
  minB      Float    @default(70)
  minBC     Float    @default(65)
  minC      Float    @default(56)
  minD      Float    @default(40)
  // Bobot skala 4 per slot
  bobotA    Float    @default(4.0)
  bobotAB   Float    @default(3.5)
  bobotB    Float    @default(3.0)
  bobotBC   Float    @default(2.5)
  bobotC    Float    @default(2.0)
  bobotD    Float    @default(1.0)
  bobotE    Float    @default(0.0)
  // Label huruf yang ditampilkan — bisa di-customize (mis. "B+" alih AB).
  // Slot internal tetap A/AB/B/BC/C/D/E utk logika, label utk display.
  hurufA    String   @default("A")
  hurufAB   String   @default("AB")
  hurufB    String   @default("B")
  hurufBC   String   @default("BC")
  hurufC    String   @default("C")
  hurufD    String   @default("D")
  hurufE    String   @default("E")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ============================================================
// KEUANGAN
// ============================================================

enum JenisTagihan {
  spp           // legacy — gunakan ukt untuk data baru
  ukt           // Uang Kuliah Tunggal per semester (penuh)
  cicilan_ukt   // Cicilan bulanan UKT (1 dari N)
  uang_pangkal  // Uang pangkal (sekali, saat masuk)
  pembangunan
  praktikum
  wisuda
  ujian
  lainnya
}

enum StatusTagihan {
  belum_bayar
  cicil
  lunas
  jatuh_tempo
}

model Tagihan {
  id          String        @id @default(uuid())
  mahasiswaId String
  mahasiswa   Mahasiswa     @relation(fields: [mahasiswaId], references: [id])
  semesterId  String
  semester    Semester      @relation(fields: [semesterId], references: [id])
  jenis       JenisTagihan
  deskripsi   String
  jumlah      Decimal       @db.Decimal(15, 2)
  jatuhTempo  DateTime
  status      StatusTagihan @default(belum_bayar)

  pembayaran  Pembayaran[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([mahasiswaId])
  @@index([semesterId])
  @@index([status])
}

enum MetodeBayar {
  transfer_bank
  va
  tunai
  qris
  ewallet
}

/// Status verifikasi bukti pembayaran oleh akademik.
enum StatusPembayaran {
  menunggu       // mahasiswa upload bukti, menunggu verifikasi
  disetujui      // diverifikasi & masuk rekonsiliasi
  ditolak        // ditolak (bukti tidak valid)
}

model Pembayaran {
  id              String           @id @default(uuid())
  tagihanId       String
  tagihan         Tagihan          @relation(fields: [tagihanId], references: [id])
  mahasiswaId     String
  mahasiswa       Mahasiswa        @relation(fields: [mahasiswaId], references: [id])
  jumlah          Decimal          @db.Decimal(15, 2)
  tanggalBayar    DateTime
  metode          MetodeBayar
  buktiUrl        String?
  catatan         String?          @db.Text
  // Status verifikasi
  status          StatusPembayaran @default(disetujui)
  // Rekonsiliasi bank
  bankPengirim    String?          // mis. "BSI" (bank pengirim)
  bankPenerima    String?          // mis. "BSI" (bank penerima kampus)
  noReferensi     String?          // no transaksi / no referensi bank
  // Validasi
  divalidasiOleh  String?
  validasiPada    DateTime?
  catatanValidasi String?          @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tagihanId])
  @@index([mahasiswaId])
  @@index([status])
  @@index([tanggalBayar])
}

// ============================================================
// TRI DHARMA — Penelitian, Pengabdian, KKN
// ============================================================

enum StatusKegiatan {
  proposal
  disetujui
  berjalan
  selesai
  ditolak
}

model Penelitian {
  id            String                @id @default(uuid())
  judul         String
  abstrak       String?               @db.Text
  tahun         Int
  sumberDana    String?
  jumlahDana    Decimal?              @db.Decimal(15, 2)
  ketuaDosenId  String
  ketuaDosen    Dosen                 @relation(fields: [ketuaDosenId], references: [id])
  status        StatusKegiatan        @default(proposal)

  mahasiswa     PenelitianMahasiswa[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([ketuaDosenId])
  @@index([tahun])
}

model PenelitianMahasiswa {
  id           String     @id @default(uuid())
  penelitianId String
  penelitian   Penelitian @relation(fields: [penelitianId], references: [id], onDelete: Cascade)
  mahasiswaId  String
  mahasiswa    Mahasiswa  @relation(fields: [mahasiswaId], references: [id])
  peran        String

  @@unique([penelitianId, mahasiswaId])
}

model Pengabdian {
  id            String                @id @default(uuid())
  judul         String
  deskripsi     String?               @db.Text
  tahun         Int
  lokasi        String?
  sumberDana    String?
  jumlahDana    Decimal?              @db.Decimal(15, 2)
  ketuaDosenId  String
  ketuaDosen    Dosen                 @relation(fields: [ketuaDosenId], references: [id])
  status        StatusKegiatan        @default(proposal)

  mahasiswa     PengabdianMahasiswa[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([ketuaDosenId])
  @@index([tahun])
}

model PengabdianMahasiswa {
  id           String     @id @default(uuid())
  pengabdianId String
  pengabdian   Pengabdian @relation(fields: [pengabdianId], references: [id], onDelete: Cascade)
  mahasiswaId  String
  mahasiswa    Mahasiswa  @relation(fields: [mahasiswaId], references: [id])
  peran        String

  @@unique([pengabdianId, mahasiswaId])
}

enum StatusKkn {
  pendaftaran
  ditugaskan
  berjalan
  selesai
}

model Kkn {
  id             String    @id @default(uuid())
  mahasiswaId    String
  mahasiswa      Mahasiswa @relation(fields: [mahasiswaId], references: [id])
  periode        String    // "2025 Genap"
  lokasi         String
  desa           String?
  kecamatan      String?
  kabupaten      String?
  dplDosenId     String?
  dplDosen       Dosen?    @relation("DplKkn", fields: [dplDosenId], references: [id])
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  nilai          String?
  status         StatusKkn @default(pendaftaran)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([mahasiswaId])
}

// ============================================================
// MBKM — Merdeka Belajar Kampus Merdeka
// 8 Bentuk Kegiatan Pembelajaran (BKP) yang diakui di SKS
// ============================================================

enum JenisMbkm {
  pertukaran_mahasiswa
  magang_industri
  asistensi_mengajar
  penelitian
  proyek_kemanusiaan
  kewirausahaan
  studi_independen
  kkn_tematik
}

enum StatusMbkm {
  pengajuan
  disetujui
  berjalan
  selesai
  ditolak
}

model Mbkm {
  id              String         @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa      @relation(fields: [mahasiswaId], references: [id])

  jenis           JenisMbkm
  namaProgram     String         // "Studi Independen Bersertifikat Bangkit"
  mitra           String         // "Bangkit Academy by Google/GoTo/Tokopedia"
  lokasi          String?
  periode         String         // semester "20251"

  dplDosenId      String?
  dplDosen        Dosen?         @relation("DplMbkm", fields: [dplDosenId], references: [id])

  tanggalMulai    DateTime?
  tanggalSelesai  DateTime?

  status          StatusMbkm     @default(pengajuan)
  catatan         String?        @db.Text

  linkProposal    String?        @db.Text
  linkLaporan     String?        @db.Text
  linkSertifikat  String?        @db.Text

  konversi        MbkmKonversi[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([mahasiswaId])
  @@index([status])
  @@index([periode])
}

model MbkmKonversi {
  id           String     @id @default(uuid())
  mbkmId       String
  mbkm         Mbkm       @relation(fields: [mbkmId], references: [id], onDelete: Cascade)
  mataKuliahId String
  mataKuliah   MataKuliah @relation(fields: [mataKuliahId], references: [id])

  nilaiHuruf   String?    // A, AB, B, …
  bobot        Float?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([mbkmId, mataKuliahId])
  @@index([mataKuliahId])
}

// ============================================================
// SKRIPSI / Tugas Akhir
// Mahasiswa mengajukan judul → akademik validasi + assign pembimbing →
// lifecycle: diajukan → disetujui → proposal → penelitian → sidang → lulus
// ============================================================

enum StatusSkripsi {
  diajukan
  disetujui
  proposal
  penelitian
  sidang
  lulus
  ditolak
  batal
}

model Skripsi {
  id              String         @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa      @relation(fields: [mahasiswaId], references: [id])

  judul           String         @db.Text
  abstrak         String?        @db.Text
  topik           String?

  status          StatusSkripsi  @default(diajukan)
  catatan         String?        @db.Text

  pembimbing1Id   String?
  pembimbing1     Dosen?         @relation("Pembimbing1Skripsi", fields: [pembimbing1Id], references: [id])
  pembimbing2Id   String?
  pembimbing2     Dosen?         @relation("Pembimbing2Skripsi", fields: [pembimbing2Id], references: [id])

  tanggalAjuan      DateTime     @default(now())
  tanggalDisetujui  DateTime?
  tanggalSidang     DateTime?
  nilaiHuruf        String?
  linkDokumen       String?      @db.Text

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([mahasiswaId])
  @@index([status])
  @@index([pembimbing1Id])
  @@index([pembimbing2Id])
}

// ============================================================
// WISUDA / YUDISIUM
// Periode wisuda dibuat akademik, mahasiswa daftar jika memenuhi syarat
// IPK + SKS + skripsi lulus + tidak ada nilai E.
// ============================================================

model PeriodeWisuda {
  id                  String    @id @default(uuid())
  kode                String    @unique // "2026-1"
  nama                String                  // "Wisuda Periode I 2026"
  tanggal             DateTime
  isPendaftaranBuka   Boolean   @default(true)
  batasIpk            Float?                  // mis. 2.00
  batasSks            Int?                    // mis. 144

  yudisium            Yudisium[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

enum StatusYudisium {
  pendaftaran   // baru daftar, belum diverifikasi
  verifikasi    // sedang dicek akademik
  layak         // memenuhi syarat, siap wisuda
  tidak_layak   // ditolak
  wisuda        // sudah diwisuda, no ijazah keluar
  batal
}

enum PredikatYudisium {
  cumlaude
  sangat_memuaskan
  memuaskan
  tidak_lulus
}

model Yudisium {
  id              String           @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa        @relation(fields: [mahasiswaId], references: [id])
  periodeWisudaId String
  periodeWisuda   PeriodeWisuda    @relation(fields: [periodeWisudaId], references: [id])

  status          StatusYudisium   @default(pendaftaran)
  ipk             Float                              // snapshot saat daftar
  sksLulus        Int                                // snapshot saat daftar
  predikat        PredikatYudisium?
  catatan         String?          @db.Text
  noIjazah        String?
  noSkl           String?
  tanggalLulus    DateTime?

  // Token publik untuk verifikasi ijazah via QR code.
  // Di-generate saat status berubah ke 'lulus' (atau manual regen).
  verifikasiToken String?          @unique

  // PDDikti sync tracking
  feederId        String?          @unique
  lastSyncedAt    DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([mahasiswaId, periodeWisudaId])
  @@index([periodeWisudaId])
  @@index([status])
}

// ============================================================
// BEASISWA — master beasiswa + pendaftaran per mahasiswa
// ============================================================

model Beasiswa {
  id              String                  @id @default(uuid())
  kode            String                  @unique // "BIDIKMISI-2026-1"
  nama            String
  penyelenggara   String                                                     // "Kemendikbud", "Tazkia Foundation"
  deskripsi       String?                 @db.Text
  kuota           Int?                                                       // kuota penerima, null = tak terbatas
  nominal         Decimal                 @db.Decimal(15, 2)                  // per penerima per periode (Rp)
  // Beasiswa dapat berupa nominal tetap, atau persentase dari UKT.
  // - persentase=100 → full coverage UKT (mahasiswa tidak ditagih)
  // - persentase=50  → diskon 50% UKT
  // - persentase=null + nominal>0 → potongan tetap (Rp) dari UKT
  persentase      Float?                                                     // 0-100, opsional
  // Beasiswa ini mengurangi tagihan UKT (default true). Kalau false,
  // beasiswa dipakai utk hal lain (mis. tunjangan), tidak memotong tagihan.
  potongUkt       Boolean                 @default(true)
  syaratIpk       Float?                                                     // IPK minimal
  syaratAngkatanMin Int?
  syaratAngkatanMax Int?
  pendaftaranBuka Boolean                 @default(true)
  tanggalBuka     DateTime?
  tanggalTutup    DateTime?

  pendaftaran     PendaftaranBeasiswa[]

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

enum StatusPendaftaranBeasiswa {
  diajukan
  dalam_seleksi
  diterima
  ditolak
  batal
}

model PendaftaranBeasiswa {
  id              String                    @id @default(uuid())
  beasiswaId      String
  beasiswa        Beasiswa                  @relation(fields: [beasiswaId], references: [id], onDelete: Cascade)
  mahasiswaId     String
  mahasiswa       Mahasiswa                 @relation(fields: [mahasiswaId], references: [id])

  status          StatusPendaftaranBeasiswa @default(diajukan)
  catatan         String?                   @db.Text
  motivasi        String                    @db.Text
  linkDokumen     String?                   @db.Text
  ipkSaatDaftar   Float
  semesterSaatDaftar String                                                  // "20251"

  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([beasiswaId, mahasiswaId])
  @@index([beasiswaId])
  @@index([mahasiswaId])
  @@index([status])
}

// ============================================================
// SURAT KETERANGAN — permohonan mahasiswa dengan validasi akademik
// Contoh: surat aktif kuliah, pengantar beasiswa, izin penelitian, KTM
// ============================================================

enum JenisSurat {
  aktif_kuliah
  keterangan_mahasiswa
  pengantar_beasiswa
  pengantar_penelitian
  pengantar_magang
  pengganti_ktm
  lainnya
}

enum StatusSurat {
  diajukan
  disetujui
  ditolak
  selesai
  batal
}

model Surat {
  id              String      @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa   @relation(fields: [mahasiswaId], references: [id])

  jenis           JenisSurat
  judul           String                                                     // header surat custom (mis. "Surat Pengantar Magang")
  keperluan       String      @db.Text                                       // tujuan/keperluan dari mahasiswa
  status          StatusSurat @default(diajukan)
  catatan         String?     @db.Text                                       // dari akademik
  nomorSurat      String?                                                    // diisi akademik saat menerbitkan
  tanggalDiajukan DateTime    @default(now())
  tanggalDisetujui DateTime?
  tanggalSelesai  DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([mahasiswaId])
  @@index([status])
  @@index([jenis])
}

// ============================================================
// EDOM — Evaluasi Dosen oleh Mahasiswa
// Kuesioner aktif per semester, mahasiswa isi per kelas (kombo dosen+MK)
// Akademik lihat rekap rata-rata per aspek per dosen
// ============================================================

model EdomKuesioner {
  id         String    @id @default(uuid())
  judul      String
  semesterId String
  semester   Semester  @relation(fields: [semesterId], references: [id])
  isAktif    Boolean   @default(false)

  aspek      EdomAspek[]
  response   EdomResponse[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([semesterId])
  @@index([isAktif])
}

model EdomAspek {
  id          String        @id @default(uuid())
  kuesionerId String
  kuesioner   EdomKuesioner @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  urutan      Int
  pertanyaan  String        @db.Text

  jawaban     EdomJawaban[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([kuesionerId, urutan])
}

model EdomResponse {
  id           String        @id @default(uuid())
  kuesionerId  String
  kuesioner    EdomKuesioner @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  mahasiswaId  String
  mahasiswa    Mahasiswa     @relation(fields: [mahasiswaId], references: [id])
  kelasId      String
  kelas        Kelas         @relation(fields: [kelasId], references: [id])

  submittedAt  DateTime      @default(now())

  jawaban      EdomJawaban[]

  @@unique([kuesionerId, mahasiswaId, kelasId])
  @@index([kelasId])
}

model EdomJawaban {
  id         String       @id @default(uuid())
  responseId String
  response   EdomResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  aspekId    String
  aspek      EdomAspek    @relation(fields: [aspekId], references: [id], onDelete: Cascade)
  nilai      Int          // 1-5 likert

  @@unique([responseId, aspekId])
}

// ============================================================
// PENGUMUMAN (broadcast sederhana)
// ============================================================

model Pengumuman {
  id        String   @id @default(uuid())
  judul     String
  isi       String   @db.Text
  pengirim  String?
  target    String?  // "all" | "mahasiswa" | "dosen" | "prodi:<id>"
  tanggal   DateTime @default(now())
  isPenting Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([target])
  @@index([tanggal])
}

// ============================================================
// KALENDER AKADEMIK — event terjadwal (UTS/UAS, libur, deadline KRS, dll)
// Dibaca semua role; di-kelola hanya akademik.
// ============================================================

enum JenisEventKalender {
  ujian          // UTS / UAS / kuis terjadwal kampus
  libur          // hari libur akademik
  registrasi     // KRS, PRS, pembayaran
  wisuda         // periode yudisium / wisuda
  akademik       // event akademik lain
  lain
}

model KalenderAkademik {
  id             String             @id @default(uuid())
  judul          String
  deskripsi      String?            @db.Text
  jenis          JenisEventKalender @default(akademik)
  tanggalMulai   DateTime
  tanggalSelesai DateTime?
  target         String             @default("all") // "all" | "mahasiswa" | "dosen"
  warna          String?            // hex / token CSS (opsional, untuk badge)
  semesterId     String?
  semester       Semester?          @relation(fields: [semesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tanggalMulai])
  @@index([semesterId])
  @@index([target])
}

// ============================================================
// KONSULTASI DPA — booking sesi konsultasi mahasiswa ↔ DPA + log catatan.
// Workflow: mahasiswa request → DPA accept/reject → DPA mark selesai (catatan)
// ============================================================

enum StatusKonsultasi {
  diajukan
  diterima
  ditolak
  selesai
  batal
}

// ============================================================
// KUIS ONLINE — soal pilihan ganda + attempt mahasiswa + auto-grade.
// Workflow: dosen buat kuis → add soal → publish → mahasiswa kerjakan
// (mulai/submit) → backend hitung skor otomatis.
// ============================================================

enum StatusKuisAttempt {
  berjalan
  submit
  expired
}

model Kuis {
  id               String      @id @default(uuid())
  kelasId          String
  kelas            Kelas       @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  judul            String
  deskripsi        String?     @db.Text
  durasiMenit      Int         @default(30)
  mulai            DateTime
  selesai          DateTime
  acak             Boolean     @default(true)  // acak urutan soal saat attempt
  isPublished      Boolean     @default(false)
  /// Jika true, persen attempt mahasiswa ikut dihitung dalam rerata
  /// kolom "Tugas" di Input Nilai (bersama SubmitTugas yang sudah dinilai).
  masukNilaiTugas  Boolean     @default(false)

  soal             KuisSoal[]
  attempt          KuisAttempt[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([kelasId])
}

model KuisSoal {
  id         String   @id @default(uuid())
  kuisId     String
  kuis       Kuis     @relation(fields: [kuisId], references: [id], onDelete: Cascade)
  urutan     Int      @default(0)
  pertanyaan String   @db.Text
  opsi       Json     // ["a","b","c","d"] - urutan opsi
  jawaban    Int      // index opsi yang benar (0-based)
  bobot      Int      @default(1)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([kuisId])
}

model KuisAttempt {
  id          String            @id @default(uuid())
  kuisId      String
  kuis        Kuis              @relation(fields: [kuisId], references: [id], onDelete: Cascade)
  mahasiswaId String
  mahasiswa   Mahasiswa         @relation(fields: [mahasiswaId], references: [id])
  mulaiPada   DateTime          @default(now())
  selesaiPada DateTime?
  status      StatusKuisAttempt @default(berjalan)
  jawaban     Json              // { [soalId]: number } — pilihan mahasiswa
  skor        Int?              // total bobot dari jawaban benar
  maxSkor     Int?              // total bobot semua soal saat submit
  persen      Float?            // skor / maxSkor * 100

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kuisId, mahasiswaId])
  @@index([kuisId])
  @@index([mahasiswaId])
}

model KonsultasiDpa {
  id          String           @id @default(uuid())
  mahasiswaId String
  mahasiswa   Mahasiswa        @relation(fields: [mahasiswaId], references: [id])
  dpaId       String
  dpa         Dosen            @relation(fields: [dpaId], references: [id])
  topik       String
  agenda      String?          @db.Text   // diisi mahasiswa saat request
  waktuMulai  DateTime         // slot yang diminta / disetujui
  durasiMenit Int              @default(30)
  status      StatusKonsultasi @default(diajukan)
  catatanDpa  String?          @db.Text   // diisi DPA saat selesai/tolak
  tanggalSelesai DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([mahasiswaId])
  @@index([dpaId])
  @@index([status])
  @@index([waktuMulai])
}

// ============================================================
// HELPDESK / TIKET LAYANAN — mahasiswa lapor masalah, akademik tangani.
// Thread reply terbuka untuk dua arah sampai status closed.
// ============================================================

enum KategoriTiket {
  krs
  keuangan
  akun
  nilai
  layanan
  lain
}

enum StatusTiket {
  terbuka
  proses
  menunggu_user
  selesai
  ditutup
}

enum PrioritasTiket {
  rendah
  normal
  tinggi
}

model Tiket {
  id          String         @id @default(uuid())
  mahasiswaId String
  mahasiswa   Mahasiswa      @relation(fields: [mahasiswaId], references: [id])
  kategori    KategoriTiket
  judul       String
  deskripsi   String         @db.Text
  status      StatusTiket    @default(terbuka)
  prioritas   PrioritasTiket @default(normal)
  tanggalTutup DateTime?

  replies     TiketReply[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([mahasiswaId])
  @@index([status])
  @@index([kategori])
}

model TiketReply {
  id        String   @id @default(uuid())
  tiketId   String
  tiket     Tiket    @relation(fields: [tiketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  authorRole String  // mahasiswa | akademik — snapshot agar tetap terbaca
  isi       String   @db.Text

  createdAt DateTime @default(now())

  @@index([tiketId])
}

// ============================================================
// SERTIFIKASI & PRESTASI — sumber data SKPI (Surat Keterangan
// Pendamping Ijazah). Mahasiswa input → akademik verifikasi.
// ============================================================

enum JenisSertifikasi {
  bahasa       // TOEFL, IELTS, TOEIC, Bahasa Arab, dll
  kompetensi   // MTCNA, AWS, Oracle, Cisco, dll
  pelatihan    // course / workshop completion
  lain
}

enum LevelKegiatan {
  internasional
  nasional
  regional
  lokal
  internal
}

enum StatusVerifikasi {
  draft        // mahasiswa input, belum submit
  diajukan     // submit untuk verifikasi
  diverifikasi // akademik approve
  ditolak      // akademik reject
}

model Sertifikasi {
  id                 String           @id @default(uuid())
  mahasiswaId        String
  mahasiswa          Mahasiswa        @relation(fields: [mahasiswaId], references: [id])
  jenis              JenisSertifikasi
  nama               String           // "TOEFL ITP", "MTCNA"
  penerbit           String           // "ETS", "Mikrotik"
  nomorSertifikat    String?
  tanggalTerbit      DateTime
  tanggalKadaluwarsa DateTime?
  level              LevelKegiatan?
  skor               String?          // "550", "Band 6.5", "Pass"
  fileUrl            String?          // link bukti / foto sertifikat
  status             StatusVerifikasi @default(draft)
  catatanVerifikator String?          @db.Text
  diverifikasiOleh   String?
  diverifikasiPada   DateTime?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([mahasiswaId])
  @@index([status])
}

enum JenisPrestasi {
  lomba_akademik
  lomba_non_akademik
  kepanitiaan
  organisasi
  publikasi
  lain
}

// ============================================================
// MUTASI MAHASISWA — riwayat perubahan status (cuti, pindah prodi,
// aktif kembali, drop out, mengundurkan diri). Workflow: mahasiswa
// request → akademik approve/reject → status mahasiswa di-update
// atomik. Snapshot status sebelum/sesudah untuk audit.
// ============================================================

enum JenisMutasi {
  cuti
  aktif_kembali
  pindah_prodi
  drop_out
  mengundurkan_diri
}

enum StatusMutasi {
  diajukan
  disetujui
  ditolak
  batal
}

model MutasiMahasiswa {
  id              String          @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa       @relation(fields: [mahasiswaId], references: [id])
  jenis           JenisMutasi
  statusSebelum   StatusMahasiswa // snapshot saat request
  statusSesudah   StatusMahasiswa // status target jika disetujui
  prodiAsalId     String?         // snapshot prodi saat request
  prodiAsal       Prodi?          @relation("MutasiProdiAsal", fields: [prodiAsalId], references: [id])
  prodiTujuanId   String?         // untuk pindah_prodi
  prodiTujuan     Prodi?          @relation("MutasiProdiTujuan", fields: [prodiTujuanId], references: [id])
  semesterId      String?         // semester berlaku
  semester        Semester?       @relation(fields: [semesterId], references: [id])
  alasan          String          @db.Text
  fileUrl         String?
  status          StatusMutasi    @default(diajukan)
  catatanAkademik String?         @db.Text
  diprosesPada    DateTime?
  diprosesOleh    String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([mahasiswaId])
  @@index([status])
  @@index([jenis])
}

model Prestasi {
  id                 String           @id @default(uuid())
  mahasiswaId        String
  mahasiswa          Mahasiswa        @relation(fields: [mahasiswaId], references: [id])
  jenis              JenisPrestasi
  nama               String           // "Juara 2 GEMASTIK 2024"
  penyelenggara      String?          // "Kemdikbud"
  tanggal            DateTime
  level              LevelKegiatan?
  peran              String?          // "Ketua Panitia", "Anggota Tim"
  deskripsi          String?          @db.Text
  fileUrl            String?
  status             StatusVerifikasi @default(draft)
  catatanVerifikator String?          @db.Text
  diverifikasiOleh   String?
  diverifikasiPada   DateTime?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([mahasiswaId])
  @@index([status])
}

// ============================================================
// AUDIT LOG — riwayat aksi sensitif untuk akuntabilitas
// Actor di-denormalize (actorName, actorRole) supaya tetap terbaca
// kalau user-nya nanti dihapus.
// ============================================================

// ============================================================
// NOTIFIKASI in-app — per user. Pengirim bisa mahasiswa (jarang),
// dosen, akademik, atau sistem (auto pasca aksi).
// ============================================================

model Notifikasi {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?   @db.Text
  type      String?   // "krs" | "nilai" | "tagihan" | "pembayaran" | "pengumuman" | "info"
  link      String?   // app-internal route untuk navigate
  entity    String?
  entityId  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?  // mahasiswa | dosen | akademik | system
  actorName  String?  // denormalized snapshot
  action     String   // e.g. "auth.login", "krs.approve", "nilai.finalize"
  entity     String?  // e.g. "mahasiswa", "krs", "nilai"
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// PUSAT DOKUMEN — repository file institusional (panduan akademik,
// tata tertib, kode etik, pedoman skripsi, SOP). Akademik upload &
// kelola; semua role authenticated bisa lihat sesuai target.
// ============================================================

enum AksiDokumen {
  view
  download
}

model KategoriDokumen {
  id        String   @id @default(uuid())
  kode      String   @unique // "panduan-akademik", "tata-tertib"
  nama      String   // "Panduan Akademik"
  deskripsi String?  @db.Text
  urutan    Int      @default(0)
  isAktif   Boolean  @default(true)

  dokumen   Dokumen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dokumen {
  id                 String          @id @default(uuid())
  kategoriId         String
  kategori           KategoriDokumen @relation(fields: [kategoriId], references: [id])
  judul              String
  deskripsi          String?         @db.Text
  versi              String?         // "1.0", "Rev 2024", dll
  target             String          @default("all") // "all" | "mahasiswa" | "dosen" | "prodi:<id>"
  fileUrl            String          @db.Text
  jenisFile          String?         // "pdf", "doc", "xls", "link"
  ukuranByte         Int?            // ukuran file untuk display
  tanggalBerlaku     DateTime?
  tanggalKedaluwarsa DateTime?
  isAktif            Boolean         @default(true)
  viewCount          Int             @default(0)
  downloadCount      Int             @default(0)

  akses              DokumenAkses[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kategoriId])
  @@index([target])
  @@index([isAktif])
}

model DokumenAkses {
  id        String       @id @default(uuid())
  dokumenId String
  dokumen   Dokumen      @relation(fields: [dokumenId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  aksi      AksiDokumen
  ip        String?
  userAgent String?

  createdAt DateTime     @default(now())

  @@index([dokumenId, createdAt])
  @@index([userId])
}

// ============================================================
// NEO FEEDER PDDikti — integrasi sinkronisasi data ke Kemendikbud.
// Pattern: outbox queue + idempotensi via feederId di entity utama.
// Real HTTP call ke Feeder dilakukan oleh worker; di lib/feeder/client.ts
// disediakan implementasi stub untuk pengembangan.
// ============================================================

enum FeederEntity {
  mahasiswa
  dosen
  mata_kuliah
  kelas
  krs
  nilai
  aktivitas
  yudisium
  // Phase 2 PDDikti
  akm
  komponen_evaluasi
  nilai_komponen
  daya_tampung
  mahasiswa_inbound
  nilai_transfer
}

enum FeederOperation {
  create
  update
  delete
}

enum FeederStatus {
  pending
  processing
  success
  failed
  skipped // saat dry-run
}

model FeederConfig {
  id              String  @id @default("singleton")
  baseUrl         String? // URL Feeder kampus, mis. https://feeder.tazkia.ac.id:1357
  username        String? // akun web service PDDikti
  passwordEnc     String? // password ter-enkripsi (di stub disimpan plain — ganti di prod)
  semesterAktif   String? // kode semester PDDikti yang sedang aktif disinkron
  dryRun          Boolean @default(true)   // default safe: tidak benar-benar push
  isEnabled       Boolean @default(false)
  lastTestAt      DateTime?
  lastTestStatus  String?
  lastTestMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeederQueue {
  id          String          @id @default(uuid())
  entity      FeederEntity
  entityId    String          // id lokal (mahasiswaId, krsId, dll)
  operation   FeederOperation
  payload     Json            // snapshot data saat enqueue (untuk retry)
  status      FeederStatus    @default(pending)
  attempts    Int             @default(0)
  maxAttempts Int             @default(5)
  lastError   String?         @db.Text
  nextRetryAt DateTime?
  processedAt DateTime?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, nextRetryAt])
  @@index([entity, entityId])
}

model FeederSyncLog {
  id        String        @id @default(uuid())
  entity    FeederEntity
  entityId  String
  operation FeederOperation
  status    FeederStatus
  feederId  String?       // hasil id dari PDDikti bila sukses create
  message   String?       @db.Text
  durationMs Int?

  createdAt DateTime      @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================================
// BKD — Beban Kerja Dosen. Laporan kinerja dosen per semester
// dengan 4 kategori utama: pengajaran, penelitian, pengabdian, penunjang.
// Total ekuivalen ≥12 SKS untuk dosen full-time. Workflow:
// dosen susun (auto-populate dari kelas/skripsi/penelitian) → submit
// → akademik verifikasi.
// ============================================================

enum KategoriBkd {
  pengajaran   // mengajar, bimbingan skripsi/TA, menguji
  penelitian   // penelitian, publikasi
  pengabdian   // pengabdian masyarakat
  penunjang    // kepanitiaan, pembimbing, organisasi profesi
}

enum StatusBkd {
  draft
  diajukan
  disetujui
  ditolak
}

model BkdLaporan {
  id            String     @id @default(uuid())
  dosenId       String
  dosen         Dosen      @relation(fields: [dosenId], references: [id])
  semesterId    String
  semester      Semester   @relation(fields: [semesterId], references: [id])
  status        StatusBkd  @default(draft)
  totalSks      Float      @default(0)  // total ekuivalen SKS
  catatanDosen  String?    @db.Text
  catatanAkademik String?  @db.Text
  diverifikasiOleh String?
  diverifikasiPada DateTime?

  items         BkdItem[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([dosenId, semesterId])
  @@index([status])
}

model BkdItem {
  id          String      @id @default(uuid())
  laporanId   String
  laporan     BkdLaporan  @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  kategori    KategoriBkd
  jenis       String      // "Mengajar Kelas", "Bimbingan Skripsi", "Penelitian (Ketua)"
  deskripsi   String      @db.Text
  bobotSks    Float       // ekuivalen SKS untuk item ini
  // Optional reference ke entity sumber (kelas/skripsi/penelitian/pengabdian)
  sumberEntity String?    // "kelas" | "skripsi" | "penelitian" | "pengabdian" | null
  sumberId    String?
  fileUrl     String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([laporanId])
  @@index([kategori])
}

// ============================================================
// WALI MAHASISWA — portal read-only untuk orang tua/wali. Wali login
// dengan akun User role=wali, terhubung ke 1+ mahasiswa via WaliMahasiswa.
// ============================================================

enum HubunganWali {
  ayah
  ibu
  kakak
  saudara
  wali_lain
}

model Wali {
  id        String           @id @default(uuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  nama      String
  telepon   String?
  alamat    String?          @db.Text
  pekerjaan String?

  mahasiswa WaliMahasiswa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WaliMahasiswa {
  id          String        @id @default(uuid())
  waliId      String
  wali        Wali          @relation(fields: [waliId], references: [id], onDelete: Cascade)
  mahasiswaId String
  mahasiswa   Mahasiswa     @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  hubungan    HubunganWali  @default(wali_lain)

  createdAt   DateTime      @default(now())

  @@unique([waliId, mahasiswaId])
  @@index([mahasiswaId])
}

// ============================================================
// OBE — Outcome-Based Education (CPL & CPMK).
// CPL = Capaian Pembelajaran Lulusan (per prodi, level KKNI).
// CPMK = Capaian Pembelajaran Mata Kuliah (per MK).
// Mapping CPMK↔CPL many-to-many dengan bobot kontribusi.
// Penilaian per CPMK di tabel NilaiCpmk per KRS untuk laporan
// capaian CPL ke akreditasi BAN-PT.
// ============================================================

enum AspekCpl {
  sikap
  pengetahuan
  ketrampilan_umum
  ketrampilan_khusus
}

enum StatusCpmk {
  belum
  tercapai       // ≥ ambang batas (default 56 / nilai C)
  belum_tercapai
}

model Cpl {
  id        String   @id @default(uuid())
  prodiId   String
  prodi     Prodi    @relation(fields: [prodiId], references: [id], onDelete: Cascade)
  kode      String   // "CPL-1", "S1", "P1"
  deskripsi String   @db.Text
  aspek     AspekCpl
  isAktif   Boolean  @default(true)
  urutan    Int      @default(0)

  cpmk      CpmkCpl[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prodiId, kode])
  @@index([aspek])
}

model Cpmk {
  id            String     @id @default(uuid())
  mataKuliahId  String
  mataKuliah    MataKuliah @relation(fields: [mataKuliahId], references: [id], onDelete: Cascade)
  kode          String     // "CPMK-1", "M1"
  deskripsi     String     @db.Text
  bobotPenilaian Float     @default(1.0)   // weight relatif dalam total nilai MK
  ambangTercapai Float     @default(56)    // skor min untuk dianggap tercapai (default nilai C)
  isAktif       Boolean    @default(true)
  urutan        Int        @default(0)

  cpl           CpmkCpl[]
  nilai         NilaiCpmk[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([mataKuliahId, kode])
}

model CpmkCpl {
  cpmkId    String
  cplId     String
  cpmk      Cpmk     @relation(fields: [cpmkId], references: [id], onDelete: Cascade)
  cpl       Cpl      @relation(fields: [cplId], references: [id], onDelete: Cascade)
  bobot     Float    @default(1.0)   // kontribusi CPMK ini ke CPL (0–1)

  createdAt DateTime @default(now())

  @@id([cpmkId, cplId])
  @@index([cplId])
}

model NilaiCpmk {
  id      String     @id @default(uuid())
  krsId   String
  krs     Krs        @relation(fields: [krsId], references: [id], onDelete: Cascade)
  cpmkId  String
  cpmk    Cpmk       @relation(fields: [cpmkId], references: [id], onDelete: Cascade)
  nilai   Float                                       // 0-100
  status  StatusCpmk @default(belum)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([krsId, cpmkId])
  @@index([cpmkId])
}

// ============================================================
// SERTIFIKAT DIGITAL — generator sertifikat untuk KKN, MBKM, EDOM,
// workshop, kepanitiaan, dll. Dilengkapi QR untuk verifikasi publik.
// Auto-issued saat KKN/MBKM selesai; bisa di-create manual oleh akademik.
// ============================================================

enum JenisSertifikatDigital {
  kkn
  mbkm
  edom
  workshop
  panitia
  asisten
  lain
}

enum StatusSertifikatDigital {
  terbit
  dicabut
}

model SertifikatDigital {
  id              String                  @id @default(uuid())
  mahasiswaId     String
  mahasiswa       Mahasiswa               @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  jenis           JenisSertifikatDigital
  judul           String
  deskripsi       String?                 @db.Text
  nomorSertifikat String                  @unique // "SRT/KKN/2026/001"
  tanggalTerbit   DateTime                @default(now())

  // Reference ke entity sumber (KKN/MBKM/EDOM) — opsional
  sumberEntity    String?                 // "kkn" | "mbkm" | "edom"
  sumberId        String?

  // Periode untuk display ("Ganjil 2025/2026", "2026 Genap")
  periode         String?

  // Pejabat penandatangan
  ttdNama         String?
  ttdJabatan      String?

  // Public verifikasi via QR
  verifikasiToken String                  @unique

  status          StatusSertifikatDigital @default(terbit)
  alasanCabut     String?                 @db.Text
  dicabutPada     DateTime?
  dicabutOleh     String?

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([mahasiswaId])
  @@index([jenis])
  @@index([sumberEntity, sumberId])
  @@index([status])
}

// ============================================================
// SPMI — Sistem Penjaminan Mutu Internal (Permenristekdikti 39/2025).
// Mengimplementasikan siklus PPEPP: Penetapan, Pelaksanaan, Evaluasi,
// Pengendalian, Peningkatan. Komponen: Standar Mutu + Pengukuran,
// Audit Mutu Internal (AMI) + Temuan + CAPA, Rapat Tinjauan Manajemen
// (RTM), Survei Kepuasan stakeholders.
// ============================================================

// -------- STANDAR MUTU --------

enum KategoriStandar {
  pendidikan            // SN-Dikti standar pendidikan
  penelitian            // SN-Dikti penelitian
  pengabdian            // SN-Dikti pengabdian
  pengelolaan           // SN-Dikti pengelolaan
  sarpras               // Sarana & prasarana
  pembiayaan            // Pembiayaan
  spmi_tambahan         // Standar tambahan/pelampauan PT
  non_akademik          // Layanan, SDM, dll
  standar_internasional // Permenristekdikti 39/2025: adaptasi standar global & pemeringkatan internasional
}

/// Sumber data otomatis untuk auto-measure.
enum SumberDataStandar {
  manual              // diisi manual oleh akademik
  ipk_lulusan         // rata-rata IPK dari Yudisium
  masa_studi          // masa studi rata-rata dari Yudisium
  tingkat_kelulusan   // % mahasiswa berstatus lulus
  edom_dosen          // rata-rata EDOM
  kehadiran_dosen     // % kehadiran pertemuan
  kehadiran_mahasiswa // % kehadiran mahasiswa
  rasio_dosen_mhs     // rasio dosen:mahasiswa
  bkd_compliance      // % dosen lapor BKD
  capaian_cpl         // rata-rata capaian CPL
}

model StandarMutu {
  id            String              @id @default(uuid())
  kode          String              @unique   // "STD-PEND-01"
  nama          String              // "IPK rata-rata lulusan ≥3.0"
  kategori      KategoriStandar
  deskripsi     String              @db.Text  // pernyataan standar
  rumusan       String?             @db.Text  // strategi / indikator
  satuan        String?             // "IPK", "%", "tahun"
  targetMin     Float?              // ambang minimal "tercapai"
  targetMax     Float?              // batas atas (untuk satuan yang lower=better mis. masa studi)
  ambangCukup   Float?              // batas "cukup" (di bawah min = belum tercapai)
  sumberData    SumberDataStandar   @default(manual)
  prodiId       String?             // null = level institusi/fakultas
  prodi         Prodi?              @relation(fields: [prodiId], references: [id])
  isAktif       Boolean             @default(true)

  pengukuran    PengukuranStandar[]
  temuan        TemuanAmi[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([kategori])
  @@index([prodiId])
}

enum StatusPencapaian {
  belum_diukur
  tercapai
  cukup
  belum_tercapai
}

model PengukuranStandar {
  id          String           @id @default(uuid())
  standarId   String
  standar     StandarMutu      @relation(fields: [standarId], references: [id], onDelete: Cascade)
  periode     String           // "20251" atau "2025"
  nilai       Float                                    // hasil pengukuran aktual
  status      StatusPencapaian @default(belum_diukur)
  catatan     String?          @db.Text
  sumberData  Json?            // snapshot data sumber (sample size, dll) saat ukur

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([standarId, periode])
  @@index([periode])
}

// -------- AMI (Audit Mutu Internal) --------

enum StatusAmi {
  perencanaan
  pelaksanaan
  selesai
  ditangguhkan
}

model AuditMutuInternal {
  id            String       @id @default(uuid())
  kode          String       @unique     // "AMI-2026-01"
  nama          String       // "Audit Mutu Internal Periode Ganjil 2025/2026"
  periode       String       // "2025/2026 Ganjil"
  tanggalMulai  DateTime
  tanggalSelesai DateTime?
  status        StatusAmi    @default(perencanaan)
  ruangLingkup  String?      @db.Text   // narasi lingkup audit
  catatan       String?      @db.Text

  // Pelaporan ke SPME (BAN-PT/LAM) — Permenristekdikti 39/2025 mensyaratkan
  // audit mutu yang transparan dan hasilnya berpengaruh langsung pada akreditasi
  // serta pemeringkatan nasional dan internasional.
  dilaporkanKeSpme      Boolean   @default(false)
  dilaporkanKeSpmePada  DateTime?
  dampakAkreditasi      String?   @db.Text  // narasi dampak hasil audit ke akreditasi/pemeringkatan

  auditor       AuditorAmi[]
  lingkup       LingkupAmi[]
  temuan        TemuanAmi[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([periode])
}

model AuditorAmi {
  id            String              @id @default(uuid())
  amiId         String
  ami           AuditMutuInternal   @relation(fields: [amiId], references: [id], onDelete: Cascade)
  dosenId       String
  dosen         Dosen               @relation(fields: [dosenId], references: [id])
  peran         String              @default("auditor") // "ketua" | "auditor"

  @@unique([amiId, dosenId])
  @@index([dosenId])
}

model LingkupAmi {
  id            String              @id @default(uuid())
  amiId         String
  ami           AuditMutuInternal   @relation(fields: [amiId], references: [id], onDelete: Cascade)
  prodiId       String
  prodi         Prodi               @relation(fields: [prodiId], references: [id])

  @@unique([amiId, prodiId])
}

enum KategoriTemuan {
  ktsm         // Ketidaksesuaian Major
  kts          // Ketidaksesuaian Minor
  observasi    // saran/observasi
  saran        // peluang perbaikan
}

model TemuanAmi {
  id            String              @id @default(uuid())
  amiId         String
  ami           AuditMutuInternal   @relation(fields: [amiId], references: [id], onDelete: Cascade)
  kode          String              // "TMN-2026-01-001"
  kategori      KategoriTemuan
  standarId     String?             // refer ke StandarMutu (opsional)
  standar       StandarMutu?        @relation(fields: [standarId], references: [id])
  deskripsi     String              @db.Text
  buktiUrl      String?             @db.Text
  rekomendasi   String?             @db.Text

  capa          TindakLanjutCapa?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([amiId, kode])
  @@index([kategori])
  @@index([standarId])
}

// -------- CAPA (Corrective & Preventive Action) --------

enum StatusCapa {
  rencana
  pelaksanaan
  verifikasi
  closed
  ditolak
}

model TindakLanjutCapa {
  id            String       @id @default(uuid())
  temuanId      String       @unique
  temuan        TemuanAmi    @relation(fields: [temuanId], references: [id], onDelete: Cascade)
  // Akar masalah & rencana
  akarMasalah   String?      @db.Text
  rencanaTindakan String     @db.Text
  picUserId     String?
  picUser       User?        @relation("CapaPic", fields: [picUserId], references: [id])
  picDosenId    String?
  picDosen      Dosen?       @relation("CapaPicDosen", fields: [picDosenId], references: [id])
  targetSelesai DateTime
  // Pelaksanaan & verifikasi
  realisasiTindakan String?  @db.Text
  bukti         String?      @db.Text   // URL bukti pelaksanaan
  tanggalSelesai DateTime?
  verifikator   String?                  // userId akademik
  verifikasiPada DateTime?
  catatanVerifikasi String?  @db.Text

  status        StatusCapa   @default(rencana)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([targetSelesai])
}

// -------- RTM (Rapat Tinjauan Manajemen) --------

enum StatusRtm {
  perencanaan
  selesai
}

model RapatTinjauanManajemen {
  id            String       @id @default(uuid())
  kode          String       @unique     // "RTM-2026-01"
  judul         String       // "RTM Semester Ganjil 2025/2026"
  tanggal       DateTime
  agenda        String       @db.Text
  notulen       String?      @db.Text
  peserta       String?      @db.Text   // daftar peserta (free text atau JSON)
  status        StatusRtm    @default(perencanaan)

  keputusan     KeputusanRtm[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tanggal])
}

enum StatusKeputusanRtm {
  open
  in_progress
  done
  cancelled
}

model KeputusanRtm {
  id            String                   @id @default(uuid())
  rtmId         String
  rtm           RapatTinjauanManajemen   @relation(fields: [rtmId], references: [id], onDelete: Cascade)
  deskripsi     String                   @db.Text
  picUserId     String?
  picUser       User?                    @relation("KeputusanRtmPic", fields: [picUserId], references: [id])
  picCatatan    String?                  // nama PIC non-user (free text)
  targetSelesai DateTime?
  status        StatusKeputusanRtm       @default(open)
  catatan       String?                  @db.Text

  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([rtmId])
  @@index([status])
}

// -------- SURVEI KEPUASAN --------

enum KategoriSurvei {
  layanan_akademik
  layanan_keuangan
  layanan_sarpras
  layanan_perpustakaan
  layanan_kemahasiswaan
  dosen_pembimbing
  lulusan
  pengguna_lulusan
  lain
}

enum StatusSurvei {
  draft
  publish
  ditutup
}

model KuesionerKepuasan {
  id            String           @id @default(uuid())
  kode          String           @unique // "SRV-2026-AKD-01"
  judul         String
  deskripsi     String?          @db.Text
  kategori      KategoriSurvei
  periode       String?
  target        String           @default("mahasiswa") // "mahasiswa" | "dosen" | "alumni" | "umum"
  tokenPublic   String           @unique // untuk URL anonim publik
  status        StatusSurvei     @default(draft)
  mulai         DateTime?
  selesai       DateTime?

  pertanyaan    PertanyaanKepuasan[]
  response      ResponseKepuasan[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([kategori])
  @@index([status])
}

enum JenisPertanyaanKepuasan {
  likert        // skala 1-5
  pilihan       // multiple choice
  open          // free text
}

model PertanyaanKepuasan {
  id            String                  @id @default(uuid())
  kuesionerId   String
  kuesioner     KuesionerKepuasan       @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  urutan        Int                     @default(0)
  pertanyaan    String                  @db.Text
  jenis         JenisPertanyaanKepuasan @default(likert)
  wajib         Boolean                 @default(true)
  opsi          Json?                   // utk jenis 'pilihan': ["A","B"]

  jawaban       JawabanKepuasan[]

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([kuesionerId])
}

model ResponseKepuasan {
  id            String              @id @default(uuid())
  kuesionerId   String
  kuesioner     KuesionerKepuasan   @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  // Anonymous — tidak link ke user
  rolePelapor   String?             // "mahasiswa" | "dosen" | "alumni" | "umum"
  identitasOpsional String?         // free text opsional (mis. "Pengguna alumni dari PT XYZ")
  ip            String?
  userAgent     String?

  jawaban       JawabanKepuasan[]

  createdAt     DateTime            @default(now())

  @@index([kuesionerId])
}

model JawabanKepuasan {
  id            String              @id @default(uuid())
  responseId    String
  response      ResponseKepuasan    @relation(fields: [responseId], references: [id], onDelete: Cascade)
  pertanyaanId  String
  pertanyaan    PertanyaanKepuasan  @relation(fields: [pertanyaanId], references: [id], onDelete: Cascade)
  nilai         Int?                // utk likert 1-5
  pilihan       String?             // utk multiple choice
  teks          String?             @db.Text // utk open

  @@unique([responseId, pertanyaanId])
  @@index([pertanyaanId])
}

// ============================================================
// HEREGISTRASI SEMESTER + CUTI AKADEMIK
// Setiap mahasiswa wajib heregistrasi tiap semester untuk pernyataan
// aktif / cuti. Cuti = jenis heregistrasi dengan alasan + dokumen pendukung.
// Akademik memverifikasi → bila disetujui, status Mahasiswa di-sync.
// ============================================================
enum JenisHeregistrasi {
  aktif
  cuti
}

enum StatusHeregistrasi {
  diajukan
  disetujui
  ditolak
}

model Heregistrasi {
  id           String              @id @default(uuid())
  mahasiswaId  String
  mahasiswa    Mahasiswa           @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  semesterId   String
  semester     Semester            @relation(fields: [semesterId], references: [id])
  jenis        JenisHeregistrasi
  alasan       String?             @db.Text  // wajib bila jenis=cuti
  dokumenUrl   String?             @db.Text  // surat pernyataan / pendukung cuti
  status       StatusHeregistrasi  @default(diajukan)
  catatanAkademik String?          @db.Text
  diverifikasiOleh String?
  diverifikasiPada DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([mahasiswaId, semesterId])
  @@index([semesterId])
  @@index([status])
}

// ============================================================
// PDDIKTI REFERENCE TABLES — Phase 1 Neo Feeder readiness.
// Lookup enum-like tables yg PDDikti gunakan. Seed dari seed.ts.
// ============================================================

model KodeAgama {
  kode      Int    @id // 1=Islam, 2=Kristen Protestan, 3=Katolik, 4=Hindu, 5=Buddha, 6=Khonghucu, 99=Lainnya
  nama      String

  mahasiswa Mahasiswa[]
  dosen     Dosen[]    @relation("DosenAgama")

  @@map("ref_agama")
}

model KodeJenisTinggal {
  kode      Int    @id // 1=Bersama Ortu, 2=Asrama, 3=Kos/Sewa, 4=Rumah Sendiri, 5=Tinggal di Rumah Keluarga, 6=Lainnya
  nama      String

  mahasiswa Mahasiswa[]

  @@map("ref_jenis_tinggal")
}

model KodeAlatTransportasi {
  kode      Int    @id // 1=Jalan Kaki, 2=Sepeda, 3=Sepeda Motor, 4=Mobil Pribadi, 5=Angkutan Umum, 6=Kereta Api, 7=Kapal/Perahu, 8=Lainnya
  nama      String

  mahasiswa Mahasiswa[]

  @@map("ref_alat_transportasi")
}

model KodeJalurMasuk {
  kode      String @id @db.VarChar(20) // SNMPTN, SBMPTN, MANDIRI, KIPK, PRESTASI, KERJASAMA, TRANSFER, LAINNYA
  nama      String

  mahasiswa Mahasiswa[]

  @@map("ref_jalur_masuk")
}

// ============================================================
// ORANG TUA / WALI MAHASISWA — biodata utk laporan PDDikti.
// Beda dengan WaliMahasiswa (akun login wali untuk dashboard) —
// ini purely data tentang orang tua/wali (NIK, pendidikan, dst).
// ============================================================

enum JenisOrangTua {
  ayah
  ibu
  wali
}

model OrangTuaMahasiswa {
  id          String        @id @default(uuid())
  mahasiswaId String
  mahasiswa   Mahasiswa     @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  jenis       JenisOrangTua
  nama        String
  nik         String?       @db.VarChar(16)
  tahunLahir  Int?
  pendidikan  String?       // sd/smp/sma/d1/d2/d3/d4/s1/s2/s3/profesi/tidak_sekolah
  pekerjaan   String?
  penghasilan Decimal?      @db.Decimal(15, 2) // Rupiah per bulan

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([mahasiswaId, jenis])
  @@index([mahasiswaId])
}

// ============================================================
// AKM — AKTIVITAS KULIAH MAHASISWA per semester (Phase 2 PDDikti).
// PDDikti wajib: status mhs per semester + IPS/IPK/SKS snapshot.
// Distinct dari Heregistrasi (yang fokus pada workflow cuti) — AKM
// = laporan akademik per semester yang dilaporkan ke Neo Feeder.
// Sumber data: dihitung dari Nilai (IPS) + akumulasi (IPK, SKS).
// ============================================================

enum StatusAkm {
  aktif              // A — kuliah reguler
  cuti               // C — cuti akademik
  non_aktif          // N — tidak registrasi tapi belum cuti formal
  kampus_merdeka     // K — MBKM aktif
  mengundurkan_diri  // U
  lulus              // L
  drop_out           // D
}

model AktivitasKuliahMahasiswa {
  id            String     @id @default(uuid())
  mahasiswaId   String
  mahasiswa     Mahasiswa  @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  semesterId    String
  semester      Semester   @relation(fields: [semesterId], references: [id])

  status        StatusAkm  @default(aktif)
  ips           Float?     // IP semester ini
  ipk           Float?     // IPK kumulatif s/d semester ini
  sksSemester   Int?       // SKS diambil semester ini
  sksTotal      Int?       // SKS lulus kumulatif
  biayaKuliah   Decimal?   @db.Decimal(15, 2) // biaya/UKT semester ini

  // PDDikti / Neo Feeder sync metadata
  feederId      String?    @unique
  lastSyncedAt  DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([mahasiswaId, semesterId])
  @@index([semesterId])
  @@index([status])
}

// ============================================================
// KOMPONEN EVALUASI per Kelas + NILAI per komponen (NeoFeeder 2.3+).
// IKU 7: MK yang ≥50% bobot evaluasinya pakai case method atau
// team-based project = MK pembelajaran inovatif.
// Pola pendataan: 1 kelas → N komponen evaluasi → setiap mhs
// (Krs) punya 1 nilai per komponen.
// Beda dengan BobotNilaiKelas: BNK = 5-slot tetap (tugas/UTS/UAS/
// praktikum/kehadiran) utk perhitungan nilai akhir lokal; komponen
// evaluasi PDDikti = N komponen dinamis untuk reporting IKU 7.
// ============================================================

enum JenisKomponenEvaluasi {
  tugas
  uts
  uas
  quiz
  praktikum
  kehadiran
  proyek
  presentasi
  laporan
  case_method          // IKU 7
  team_based_project   // IKU 7
  lainnya
}

model KomponenEvaluasiKelas {
  id                 String                 @id @default(uuid())
  kelasId            String
  kelas              Kelas                  @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  nama               String                 // "UTS", "Proyek Kelompok"
  jenis              JenisKomponenEvaluasi
  bobotPersen        Float                  // 0-100, total per kelas seharusnya 100
  deskripsi          String?                @db.Text
  // IKU 7 marker — dapat berbeda dengan jenis (mis. jenis=proyek tapi
  // metodeTeamBased=true berarti metode TBP).
  metodeCaseMethod   Boolean                @default(false)
  metodeTeamBased    Boolean                @default(false)
  urutan             Int                    @default(0)

  nilaiKomponen      NilaiKomponenEvaluasi[]

  feederId           String?                @unique
  lastSyncedAt       DateTime?

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([kelasId])
}

model NilaiKomponenEvaluasi {
  id                  String                 @id @default(uuid())
  komponenEvaluasiId  String
  komponenEvaluasi    KomponenEvaluasiKelas  @relation(fields: [komponenEvaluasiId], references: [id], onDelete: Cascade)
  krsId               String
  krs                 Krs                    @relation(fields: [krsId], references: [id], onDelete: Cascade)
  nilai               Float?                 // 0-100

  feederId            String?                @unique
  lastSyncedAt        DateTime?

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([komponenEvaluasiId, krsId])
  @@index([krsId])
}

// ============================================================
// AKTIVITAS MAHASISWA — unified MBKM, Pertukaran, Magang, Riset,
// Pengabdian, Kewirausahaan, PPL PPG, dll. PDDikti reporting Tahap 2.
// Berbeda dengan Mbkm (yg fokus 1 mhs : 1 program MBKM), model ini
// support N mhs (peserta) + N dosen pembimbing per aktivitas. Sehingga
// 1 program MBKM/PKL kelompok bisa 1 row + N pesertaAktivitas.
// ============================================================

enum JenisAktivitasMhs {
  pertukaran_pelajar       // MBKM
  magang                   // MBKM atau wajib
  asistensi_mengajar       // MBKM
  riset                    // MBKM
  pengabdian_masyarakat
  kewirausahaan
  proyek_independen
  proyek_kemanusiaan
  bela_negara
  kkn_tematik
  kerja_praktek
  studi_independen
  ppl                      // PPG
  lainnya
}

enum StatusAktivitasMhs {
  diajukan
  berjalan
  selesai
  dibatalkan
}

model AktivitasMahasiswa {
  id              String                 @id @default(uuid())
  jenis           JenisAktivitasMhs
  nama            String                 // "MBKM Bangkit Academy 2024"
  deskripsi       String?                @db.Text
  semesterId      String
  semester        Semester               @relation(fields: [semesterId], references: [id])

  lokasi          String?
  mitra           String?                // institusi mitra
  isMbkm          Boolean                @default(false)
  isFlagship      Boolean                @default(false) // MBKM Flagship vs Mandiri
  isEksternal     Boolean                @default(false) // pertukaran antar PT
  linkProposal    String?                @db.Text
  linkLaporan     String?                @db.Text
  linkSertifikat  String?                @db.Text

  tanggalMulai    DateTime?
  tanggalSelesai  DateTime?

  status          StatusAktivitasMhs     @default(diajukan)
  catatan         String?                @db.Text

  peserta         PesertaAktivitas[]
  pembimbing      PembimbingAktivitas[]

  feederId        String?                @unique
  lastSyncedAt    DateTime?

  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([semesterId])
  @@index([jenis])
  @@index([status])
}

model PesertaAktivitas {
  id           String              @id @default(uuid())
  aktivitasId  String
  aktivitas    AktivitasMahasiswa  @relation(fields: [aktivitasId], references: [id], onDelete: Cascade)
  mahasiswaId  String
  mahasiswa    Mahasiswa           @relation(fields: [mahasiswaId], references: [id])
  peran        String?             // "Ketua Tim", "Anggota"
  konversiSks  Int?                // SKS hasil konversi (max 24 reg / 36 PLPG)

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([aktivitasId, mahasiswaId])
  @@index([mahasiswaId])
}

model PembimbingAktivitas {
  id           String              @id @default(uuid())
  aktivitasId  String
  aktivitas    AktivitasMahasiswa  @relation(fields: [aktivitasId], references: [id], onDelete: Cascade)
  dosenId      String
  dosen        Dosen               @relation(fields: [dosenId], references: [id])
  peran        String?             // "Pembimbing Utama", "Pembimbing Lapangan"

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([aktivitasId, dosenId])
  @@index([dosenId])
}

// ============================================================
// DAYA TAMPUNG PRODI per periode — wajib pelaporan Tahap 1.
// Diisi sebelum semester ganjil dimulai per prodi.
// Berlaku untuk semester awal periode (mis. 20251 untuk ganjil 2025).
// ============================================================
model DayaTampungProdi {
  id                  String   @id @default(uuid())
  prodiId             String
  prodi               Prodi    @relation(fields: [prodiId], references: [id])
  semesterId          String
  semester            Semester @relation(fields: [semesterId], references: [id])

  dayaTampung         Int      // jumlah kursi yang dibuka
  jumlahDaftar        Int?     // jumlah pendaftar
  jumlahLulusSeleksi  Int?     // diterima
  jumlahRegistrasi    Int?     // yg lapor diri/aktif

  feederId            String?  @unique
  lastSyncedAt        DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([prodiId, semesterId])
  @@index([semesterId])
}

// ============================================================
// MAHASISWA INBOUND — mhs dari PT lain yang mengikuti MBKM di Tazkia.
// Distinct dari Mahasiswa (yang punya akun login internal); inbound
// adalah row reporting saja, sinkron dengan PDDikti via approval.
// ============================================================
model MahasiswaInbound {
  id              String              @id @default(uuid())
  namaMahasiswa   String
  nimAsal         String              // NIM di PT asal
  ptAsal          String              // nama PT asal
  kodeProdiAsal   String?             // kode prodi PDDikti asal
  prodiTujuanId   String
  prodiTujuan     Prodi               @relation(fields: [prodiTujuanId], references: [id])
  semesterId      String
  semester        Semester            @relation(fields: [semesterId], references: [id])

  jenisAktivitas  JenisAktivitasMhs   @default(pertukaran_pelajar)
  tanggalMulai    DateTime?
  tanggalSelesai  DateTime?
  status          StatusAktivitasMhs  @default(diajukan)

  feederId        String?             @unique
  lastSyncedAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([prodiTujuanId])
  @@index([semesterId])
}

// ============================================================
// NILAI TRANSFER / KONVERSI — generic untuk mhs pindahan, MBKM, RPL.
// Untuk pindahan: kode + nama MK asal di-tracking biar audit bisa cek.
// Untuk MBKM: MbkmKonversi tetap dipakai per program MBKM; NilaiTransfer
// lebih untuk konversi generic (transfer kredit, RPL, dll).
// ============================================================
enum SumberNilaiTransfer {
  pindahan_pt
  mbkm
  rpl
  konversi_internal
  lainnya
}

model NilaiTransfer {
  id             String              @id @default(uuid())
  mahasiswaId    String
  mahasiswa      Mahasiswa           @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  mataKuliahId   String              // MK lokal yang menerima konversi
  mataKuliah     MataKuliah          @relation(fields: [mataKuliahId], references: [id])

  // Snapshot MK asal (kalau dari PT lain)
  kodeMkAsal     String?
  namaMkAsal     String?
  sksAsal        Int?
  nilaiHurufAsal String?

  // Hasil pengakuan
  nilaiHurufAkui String              // huruf yang diakui
  bobotAkui      Float?
  sksAkui        Int                 // SKS yang diakui

  sumber         SumberNilaiTransfer @default(pindahan_pt)
  catatan        String?             @db.Text

  feederId       String?             @unique
  lastSyncedAt   DateTime?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([mahasiswaId])
  @@index([mataKuliahId])
}
