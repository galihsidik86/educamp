# ============================================================
# Tazkia SIAKAD — environment variables
# Copy to `.env` and adjust as needed.
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_DATABASE=siakad_tazkia
MYSQL_USER=siakad
MYSQL_PASSWORD=siakad_change_me
MYSQL_PORT=3306

# --- API ---
API_PORT=4000
NODE_ENV=development

# Used by Prisma & runtime. host=mysql in docker, host=localhost when running api outside docker.
DATABASE_URL=mysql://siakad:siakad_change_me@localhost:3306/siakad_tazkia

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_64_random_bytes
JWT_REFRESH_SECRET=replace_me_with_another_64_random_bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173

# --- Web ---
WEB_PORT=5173
VITE_API_BASE_URL=/api

# --- Telegram (opsional) — notifikasi admin, mis. untuk autofix runbook.
# Kalau kosong, notifikasi cukup di-log ke console (mode dev).
# Buat bot lewat @BotFather, dapatkan chat ID lewat getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
